# Environment for Chickpea's Node build target.
# Loaded automatically by `flue dev` / `flue build`. Every value below is
# offline-safe: left unset the app takes its local/offline paths and makes no
# external calls. Fill the Slack + provider creds for a live run.

# --- Slack ---
# Verifies inbound Slack request signatures. Optional here: the /admin
# Slack-connection wizard can store it instead; an env value takes precedence.
SLACK_SIGNING_SECRET=
# Bot token for outbound Slack Web API calls. Optional here: the /admin wizard
# can store it instead; an env value takes precedence.
SLACK_BOT_TOKEN=
# Bot user id used to filter self/loop messages. Unset -> taken from the
# /admin wizard (stored from auth.test) or resolved once via auth.test; an
# explicit empty string means "no bot user id" (fail-closed).
SLACK_BOT_USER_ID=
# Override the Slack Web API base URL (point at a fake Slack for offline runs).
SLACK_API_URL=
# Public base URL for Slack-visible /admin Configure links in reply footers and
# channel onboarding. Unset -> Configure is shown as a label without a link.
SLACK_TAG_PUBLIC_URL=
# Direct messages / App Home are on by default (they answer via the '*/*'
# direct-message default profile). Set to false/0/off to make the bot reachable
# only in channels. Channels are always fail-closed (explicit assignment only).
SLACK_TAG_ALLOW_DMS=

# --- Agent model ---
# Offline/dev fallback model specifier `provider/model` for an unpinned
# profile. Pinned profiles always use their saved /admin model. A fresh
# Cloudflare install seeds Default pinned to `cloudflare/@cf/zai-org/glm-5.2`;
# a fresh Node install seeds Default unpinned so local runs should either pick
# a model in /admin or set e.g. `local-stub/parity-stub-1` with LOCAL_STUB_URL.
SLACK_TAG_MODEL=

# --- Internal agent endpoint ---
# Shared internal token gating POST /agents/slack-thread/:id for EXTERNAL
# callers; the app's own agent dispatch is in-process and needs no
# configuration. Unset -> a random per-process/per-isolate token (external
# calls then cannot authenticate).
TAG_AGENT_API_TOKEN=

# --- Admin ---
# Bearer token gating every /admin route (page + API). If unset, /admin stays
# invisible and returns 404. Generate a local value with: openssl rand -hex 32
TAG_ADMIN_TOKEN=

# --- Durable transcript storage ---
# SQLite path for the durable agent transcript. Unset -> ./tmp/flue.db
# (git-ignored). Use `:memory:` for an ephemeral, per-process DB.
TAG_DB_PATH=
# App-owned config, assignment, dedupe, and snapshot state. Unset ->
# <TAG_DB_PATH>.state; use :memory: alongside an in-memory transcript DB.
SLACK_STATE_DB_PATH=

# --- Offline stub provider (openai-completions wire protocol) ---
# Register a `local-stub` provider (SLACK_TAG_MODEL=local-stub/<model>) that
# speaks OpenAI-completions; used by the offline verify harnesses.
LOCAL_STUB_URL=
# The OpenAI-completions client needs a non-empty key even offline; the stub
# ignores it. Unset -> defaults to `offline-stub-key`.
LOCAL_STUB_API_KEY=

# --- cloudflare-workers-ai provider ---
# Account id; builds the default Workers AI base URL when the explicit base
# URL below is unset.
CLOUDFLARE_ACCOUNT_ID=
# API token for the cloudflare-workers-ai provider.
CLOUDFLARE_API_TOKEN=
# Explicit Workers AI base URL. Unset -> derived from CLOUDFLARE_ACCOUNT_ID.
CLOUDFLARE_WORKERS_AI_BASE_URL=
# Optional Cloudflare API root override for /admin model discovery.
CLOUDFLARE_API_URL=

# --- anthropic provider ---
# API key for the catalog `anthropic` provider (works from this key alone).
ANTHROPIC_API_KEY=
# Optional runtime inference base URL override for the anthropic provider.
ANTHROPIC_BASE_URL=
# Optional API root override for /admin key validation and model discovery.
ANTHROPIC_API_URL=

# --- openai provider ---
# API key for the built-in `openai` provider.
OPENAI_API_KEY=
# Optional API root override for /admin key validation and model discovery.
OPENAI_API_URL=

# --- openrouter provider ---
# API key for the built-in `openrouter` provider.
OPENROUTER_API_KEY=
# Optional API root override for /admin key validation and model discovery.
OPENROUTER_API_URL=

# --- Skill import ---
# Optional GitHub token for higher API limits and private-repository skill
# imports. Used only for requests to GitHub's API and raw-content hosts.
GITHUB_TOKEN=
