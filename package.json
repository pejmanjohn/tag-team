{
  "name": "slack-flue",
  "version": "0.0.0",
  "description": "Local-first Flue workspace assistant runtime for Slack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slack-flue/slack-flue.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "test": "npm run typecheck && node --test --import tsx tests/*.test.ts",
    "test:ci": "FLUE_REQUIRE_LOOPBACK=1 npm test",
    "typecheck": "tsc --noEmit",
    "flue:build": "flue build --target node",
    "verify:admin-ui": "node scripts/verify-admin-ui.mjs",
    "prepublishOnly": "node scripts/guard-fresh-export-publish.mjs",
    "verify:oss-export": "node scripts/verify-oss-export.mjs"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.8",
    "@flue/slack": "1.0.0-beta.1",
    "@slack/web-api": "^8.0.0-rc.1",
    "hono": "^4.12.27",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.8",
    "@types/node": "26.0.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "wrangler": "4.103.0"
  }
}
