    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.8",
    "@types/node": "26.0.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "wrangler": "4.103.0"
  }
}
