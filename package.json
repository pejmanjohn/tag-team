{
  "name": "chickpea",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, model-agnostic AI agent for Slack.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pejmanjohn/chickpea.git"
  },
  "files": [
    ".dev.vars.example",
    ".env.example",
    ".nvmrc",
    "LICENSE",
    "README.md",
    "SETUP_AGENT.md",
    "assets",
    "fixtures",
    "scripts",
    "src",
    "tests",
    "types",
    "flue.config.ts",
    "slack-app-manifest.json",
    "tsconfig.json",
    "wrangler.jsonc"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "pretest": "node scripts/preflight-node-lane.mjs",
    "test": "npm run typecheck && node --test --import tsx tests/*.test.ts",
    "test:ci": "TAG_REQUIRE_LOOPBACK=1 npm test",
    "typecheck": "tsc --noEmit",
    "flue:build": "node scripts/preflight-node-lane.mjs && flue build --target node",
    "flue:build:cf": "node scripts/flue-build-cf.mjs --output dist-cf",
    "build": "npm run flue:build:cf",
    "deploy": "node scripts/deploy-with-epilogue.mjs",
    "verify:cf-smoke": "node scripts/verify-cf-smoke.mjs",
    "verify:admin-ui": "node scripts/verify-admin-ui.mjs",
    "verify:durability": "node scripts/verify-durability.mjs",
    "verify:providers": "node scripts/verify-providers.mjs",
    "verify:providers:live": "node scripts/verify-providers-live.mjs",
    "verify:oss-export": "node scripts/verify-oss-export.mjs",
    "slack:bridge": "node scripts/slack-socket-bridge.mjs",
    "reset:test-env": "node scripts/reset-test-env.mjs"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.8",
    "@flue/slack": "1.0.0-beta.1",
    "@slack/web-api": "^8.0.0-rc.1",
    "agents": "^0.14.5",
    "hono": "^4.12.27",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.8",
    "@slack/socket-mode": "^2.0.7",
    "@types/node": "26.0.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "wrangler": "4.103.0"
  },
  "overrides": {
    "@flue/slack": {
      "hono": "^4.12.27"
    }
  },
  "cloudflare": {
    "label": "Chickpea",
    "products": [
      "Workers",
      "Durable Objects",
      "Workers AI"
    ],
    "categories": [
      "ai"
    ],
    "bindings": {
      "TAG_ADMIN_TOKEN": {
        "description": "Admin token gating the /admin route. Generate one with: openssl rand -hex 32"
      }
    }
  }
}
